# Copy this file to .env on the VPS and replace every CHANGE_ME value.

APP_NAME=OpenAI Account Control Center
APP_ENV=production
APP_HOST=127.0.0.1
APP_PORT=18080
FRONTEND_PUBLIC_URL=https://example.com

AUTH_ENABLED=true
ADMIN_USERNAME=admin
ADMIN_PASSWORD=CHANGE_ME_STRONG_ADMIN_PASSWORD
SESSION_COOKIE_NAME=control_center_session
SESSION_TTL_HOURS=24
# Use true when the panel is served through HTTPS.
SESSION_COOKIE_SECURE=true

DATABASE_URL=sqlite+aiosqlite:////opt/openai-account-control/data/app.db
DATA_DIR=/opt/openai-account-control/data
EVIDENCE_DIR=/opt/openai-account-control/data/evidence

# Generate with:
# python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=CHANGE_ME

SCHEDULER_ENABLED=true
SCAN_INTERVAL_MINUTES=30
LOW_CREDITS_THRESHOLD=15.0
LOW_USAGE_PERCENT_THRESHOLD=20.0

PLAYWRIGHT_HEADLESS=true
PLAYWRIGHT_ALLOW_LOCAL_PROFILE_FALLBACK=false
PLAYWRIGHT_TIMEOUT_MS=45000
PLAYWRIGHT_LOCALE=ru-RU
PLAYWRIGHT_TIMEZONE_ID=Europe/Moscow
PLAYWRIGHT_LOCAL_AUTH_PROFILE_DIR=/opt/openai-account-control/data/playwright-local-auth
PLAYWRIGHT_LOCAL_BROWSER_EXECUTABLE=
PLAYWRIGHT_LOCAL_BROWSER_CHANNEL=
CHATGPT_BASE_URL=https://chatgpt.com
