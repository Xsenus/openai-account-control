# Application
APP_NAME=OpenAI Account Control Center
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
FRONTEND_PUBLIC_URL=http://localhost:8000

# Panel access bootstrap.
# These credentials are used to create or recover the first active operator
# when the database has no active panel users left.
AUTH_ENABLED=true
ADMIN_USERNAME=admin
ADMIN_PASSWORD=CHANGE_ME_ADMIN_PASSWORD
SESSION_COOKIE_NAME=control_center_session
SESSION_TTL_HOURS=24
SESSION_COOKIE_SECURE=false

# Database
DATABASE_URL=sqlite+aiosqlite:///./data/app.db

# Directories
DATA_DIR=./data
EVIDENCE_DIR=./data/evidence

# Playwright session-state encryption.
# Generate with:
# python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=CHANGE_ME

# Scheduler
SCHEDULER_ENABLED=true
SCAN_INTERVAL_MINUTES=30
LOW_CREDITS_THRESHOLD=15.0
LOW_USAGE_PERCENT_THRESHOLD=20.0

# Playwright
PLAYWRIGHT_HEADLESS=true
PLAYWRIGHT_ALLOW_LOCAL_PROFILE_FALLBACK=false
PLAYWRIGHT_TIMEOUT_MS=45000
PLAYWRIGHT_LOCALE=ru-RU
PLAYWRIGHT_TIMEZONE_ID=
PLAYWRIGHT_LOCAL_AUTH_PROFILE_DIR=./data/playwright-local-auth
PLAYWRIGHT_LOCAL_BROWSER_EXECUTABLE=
PLAYWRIGHT_LOCAL_BROWSER_CHANNEL=
CHATGPT_BASE_URL=https://chatgpt.com
